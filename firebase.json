{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "site": "sigaepp",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "functions/**",
      "node_modules/**",
      ".github/**",
      "config.local.js",
      "package.json",
      "package-lock.json",
      "sonar-project.properties",
      "README.md",
      "SETUP_LOCAL.md",
      "index.js"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/processos.html"
      }
    ]
  }
}

