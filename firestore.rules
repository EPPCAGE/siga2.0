rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Verifica Custom Claim {perfil} definido pela Cloud Function setUserClaims.
    // A função é chamada automaticamente após cada login. O token é renovado
    // com getIdToken(true) para que o claim fique disponível imediatamente.
    function isEP() {
      return isAuth() && request.auth.token.get('perfil', '') == 'ep';
    }

    // ---------------------------------------------------------------------------
    // config/ — leitura exige autenticação (leitura pública removida em PR #508).
    // Escrita restrita a EP: cadastro de usuários, configurações institucionais.
    // ---------------------------------------------------------------------------
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isEP();
    }

    // Processos: EP tem escrita plena. Não-EP pode atualizar dados do próprio
    // processo (questionário, POP etc.) mas NÃO pode alterar etapa nem status_ciclo
    // — campos que controlam o ciclo de vida e são validados só no servidor.
    match /processos/{procId} {
      allow read: if isAuth();
      allow create: if isEP();
      allow delete: if isEP();
      allow update: if isEP() ||
        (isAuth() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['etapa', 'status_ciclo']));
    }

    // Publicações e metodologias: somente EP publica.
    match /publicacoes/{pubId} {
      allow read: if isAuth();
      allow write: if isEP();
    }

    // KPIs e relatórios: donos escrevem seus próprios indicadores.
    match /kpis/{id}          { allow read: if isAuth(); allow write: if isAuth(); }
    match /relatorios_ind/{id}{ allow read: if isAuth(); allow write: if isAuth(); }

    // Conteúdo institucional gerenciado pelo EP.
    match /plano/{id}       { allow read: if isAuth(); allow write: if isEP(); }
    match /arquitetura/{id} { allow read: if isAuth(); allow write: if isEP(); }
    match /plano_metas/{id} { allow read: if isAuth(); allow write: if isEP(); }

    // Notificações: qualquer usuário autenticado envia/recebe.
    match /notifs/{id} { allow read: if isAuth(); allow write: if isAuth(); }

    // Sessões: cada usuário acessa apenas a própria.
    match /sessions/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    // Projetos: gerentes e EP escrevem.
    match /projPROJETOS/{id}  { allow read: if isAuth(); allow write: if isAuth(); }

    // Programas: criados e mantidos pelo EP.
    match /projPROGRAMAS/{id} { allow read: if isAuth(); allow write: if isEP(); }

    // Documento do usuário: cada um escreve apenas no próprio.
    match /usuarios/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // Fluxos (imagens dos diagramas vinculadas à arquitetura): qualquer autenticado lê; EP escreve.
    match /fluxos/{id} { allow read: if isAuth(); allow write: if isEP(); }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
