rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAuth() {
      return request.auth != null;
    }

    function isCurrentProcessOwner() {
      // Apenas o dono ATUAL pode editar (não o futuro)
      return resource.data.dono_email == request.auth.token.email;
    }

    // Qualquer usuário autenticado pode ler tudo.
    // O controle de acesso por perfil (EP/dono/gestor) é feito pelo código JavaScript.
    // Escrita é restrita por coleção conforme necessário.

    match /config/{docId} {
      allow read: if true;   // necessário para carregar USUARIOS antes do login
      allow write: if isAuth();
    }

    match /processos/{procId} {
      allow read: if isAuth();
      // Write: apenas o dono ATUAL do processo pode editar
      allow write: if isAuth() && isCurrentProcessOwner();
    }

    match /publicacoes/{pubId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /kpis/{id}         { allow read: if isAuth(); allow write: if isAuth(); }
    match /plano/{id}        { allow read: if isAuth(); allow write: if isAuth(); }
    match /trilhas/{id}      { allow read: if isAuth(); allow write: if isAuth(); }
    match /avisos/{id}       { allow read: if isAuth(); allow write: if isAuth(); }
    match /solicitacoes/{id} { allow read: if isAuth(); allow write: if isAuth(); }
    match /notifs/{id}       { allow read: if isAuth(); allow write: if isAuth(); }
    match /arquitetura/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /plano_metas/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /relatorios_ind/{id}{ allow read: if isAuth(); allow write: if isAuth(); }

    match /sessions/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /projPROJETOS/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /projPROGRAMAS/{id} { allow read: if isAuth(); allow write: if isAuth(); }

    match /usuarios/{uid} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
