rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // ---------------------------------------------------------------------------
    // NOTA DE SEGURANÇA — leia antes de modificar estas regras
    //
    // O controle de acesso por perfil (EP / dono / gestor / gerente_projeto) é
    // realizado pelo código JavaScript do cliente. As regras do Firestore garantem
    // apenas que o usuário esteja autenticado (camada mínima de proteção).
    //
    // DÍVIDA DE SEGURANÇA CONHECIDA:
    //
    // 1. config/{docId} — leitura pública (sem autenticação)
    //    Risco: expõe config/usuarios (e-mails, perfis) e config/ejs
    //    (credenciais EmailJS) a qualquer pessoa.
    //    Causa: o fluxo de auto-cadastro lê config/usuarios antes do login
    //    para verificar se o e-mail já existe no sistema.
    //    Solução futura: migrar essa verificação para uma Cloud Function
    //    autenticada via Firebase Anonymous Auth, removendo a leitura pública.
    //
    // 2. Escrita sem restrição de perfil
    //    Risco: qualquer usuário autenticado (inclusive "dono") pode escrever
    //    em qualquer coleção, contornando as restrições da UI.
    //    Solução futura: usar Firebase Custom Claims para codificar o perfil
    //    e adicionar verificações como `request.auth.token.perfil == 'ep'`
    //    nas regras de escrita das coleções críticas.
    // ---------------------------------------------------------------------------

    match /config/{docId} {
      // Leitura pública necessária para carregar config/usuarios no fluxo de
      // auto-cadastro (antes da autenticação Firebase completar).
      // Ver nota de segurança acima sobre como resolver esta dívida.
      allow read: if true;
      allow write: if isAuth();
    }

    match /processos/{procId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /publicacoes/{pubId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /kpis/{id}         { allow read: if isAuth(); allow write: if isAuth(); }
    match /plano/{id}        { allow read: if isAuth(); allow write: if isAuth(); }
    match /trilhas/{id}      { allow read: if isAuth(); allow write: if isAuth(); }
    match /avisos/{id}       { allow read: if isAuth(); allow write: if isAuth(); }
    match /solicitacoes/{id} { allow read: if isAuth(); allow write: if isAuth(); }
    match /notifs/{id}       { allow read: if isAuth(); allow write: if isAuth(); }
    match /arquitetura/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /plano_metas/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /relatorios_ind/{id}{ allow read: if isAuth(); allow write: if isAuth(); }

    match /sessions/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /projPROJETOS/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /projPROGRAMAS/{id} { allow read: if isAuth(); allow write: if isAuth(); }

    // Cada usuário pode ler qualquer perfil (necessário para exibir nomes na UI),
    // mas só pode escrever no próprio documento. Admins (EP) usam a coleção
    // config/usuarios para gerenciamento centralizado de perfis.
    match /usuarios/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
