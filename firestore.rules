rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Verifica Custom Claim {perfil} definido pela Cloud Function setUserClaims.
    // A função é chamada automaticamente após cada login. O token é renovado
    // com getIdToken(true) para que o claim fique disponível imediatamente.
    function isEP() {
      return isAuth() && request.auth.token.get('perfil', '') == 'ep';
    }

    // ---------------------------------------------------------------------------
    // config/ — leitura exige autenticação (leitura pública removida em PR #508).
    // Escrita restrita a EP: cadastro de usuários, configurações institucionais.
    // ---------------------------------------------------------------------------
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isEP();
    }

    // Processos: EP tem escrita plena. Não-EP pode atualizar dados do próprio
    // processo (questionário, POP etc.) mas NÃO pode alterar etapa nem status_ciclo
    // — campos que controlam o ciclo de vida e são validados só no servidor.
    match /processos/{procId} {
      allow read: if isAuth();
      allow create: if isEP();
      allow delete: if isEP();
      allow update: if isEP() ||
        (isAuth() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['etapa', 'status_ciclo']));
    }

    // Publicações e metodologias: somente EP publica.
    match /publicacoes/{pubId} {
      allow read: if isAuth();
      allow write: if isEP();
    }

    // KPIs e relatórios: donos escrevem seus próprios indicadores.
    match /kpis/{id}          { allow read: if isAuth(); allow write: if isAuth(); }
    match /relatorios_ind/{id}{ allow read: if isAuth(); allow write: if isAuth(); }

    // Conteúdo institucional gerenciado pelo EP.
    match /plano/{id}       { allow read: if isAuth(); allow write: if isEP(); }
    match /arquitetura/{id} { allow read: if isAuth(); allow write: if isEP(); }
    match /plano_metas/{id} { allow read: if isAuth(); allow write: if isEP(); }

    // Notificações: qualquer usuário autenticado envia/recebe.
    match /notifs/{id} { allow read: if isAuth(); allow write: if isAuth(); }

    // Sessões: cada usuário acessa apenas a própria.
    match /sessions/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    // Projetos: gerentes e EP escrevem.
    match /projPROJETOS/{id}  { allow read: if isAuth(); allow write: if isAuth(); }

    // Programas: criados e mantidos pelo EP.
    match /projPROGRAMAS/{id} { allow read: if isAuth(); allow write: if isEP(); }

    // Documento do usuário: cada um escreve apenas no próprio.
    match /usuarios/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // Fluxos (imagens dos diagramas vinculadas à arquitetura): qualquer autenticado lê; EP escreve.
    match /fluxos/{id} { allow read: if isAuth(); allow write: if isEP(); }

    // ---------------------------------------------------------------------------
    // Módulo de Workflow Dinâmico
    // Toda escrita passa pela Cloud Function (engine); regras aqui são defesa em
    // profundidade para acesso direto. A engine valida permissões antes de escrever.
    // ---------------------------------------------------------------------------

    // Modelos de processo, formulários e designer: somente EP cria/edita.
    // Todos autenticados leem (para poder iniciar workflows publicados).
    match /wf_processo_modelos/{id} {
      allow read: if isAuth();
      allow write: if isAuth() && isEP();
    }
    // FASE 3 — reservado para editor visual de fluxos (canvas BPMN)
    // wf_etapa_modelos e wf_transicao_fluxos substituirão a modelagem de
    // processos legada. Mantidas aqui para não bloquear a transição.
    match /wf_etapa_modelos/{id} {
      allow read: if isAuth();
      allow write: if isAuth() && isEP();
    }
    match /wf_transicao_fluxos/{id} {
      allow read: if isAuth();
      allow write: if isAuth() && isEP();
    }
    match /wf_formulario_modelos/{id} {
      allow read: if isAuth();
      allow write: if isAuth() && isEP();
    }

    // Instâncias: dono lê as próprias; EP/gestor leem todas.
    // Qualquer autenticado pode criar; só o solicitante ou EP/gestor podem atualizar.
    match /wf_instancia_processos/{id} {
      allow read: if isAuth() && (
        isEP() ||
        request.auth.token.get('perfil','') == 'gestor' ||
        resource.data.solicitante_uid == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isEP() ||
        request.auth.token.get('perfil','') == 'gestor' ||
        resource.data.solicitante_uid == request.auth.uid
      );
    }

    // Tarefas: responsável lê a própria; EP/gestor leem todas.
    // Qualquer autenticado pode criar (engine cria tarefas ao avançar etapa).
    // Só o responsável ou EP/gestor podem atualizar.
    match /wf_tarefa_workflows/{id} {
      allow read: if isAuth() && (
        isEP() ||
        request.auth.token.get('perfil','') == 'gestor' ||
        resource.data.responsavel_uid == request.auth.uid ||
        resource.data.responsavel_uid == null
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isEP() ||
        request.auth.token.get('perfil','') == 'gestor' ||
        resource.data.responsavel_uid == request.auth.uid ||
        resource.data.responsavel_uid == null
      );
      allow delete: if isAuth() && (isEP() || request.auth.token.get('perfil','') == 'gestor');
    }

    // Histórico: imutável — autenticados criam, ninguém deleta/atualiza.
    match /wf_historico_workflows/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Comentários: qualquer autenticado lê e cria; autor pode atualizar o próprio.
    match /wf_comentarios/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.autor_uid == request.auth.uid;
    }

    // Grupos de responsáveis dinâmicos
    match /wf_grupos/{id} {
      allow read: if isAuth();
      allow write: if isAuth() && isEP();
    }

    // Notificações: cada usuário lê/marca as próprias; EP lê escaladas de SLA; sistema cria.
    match /wf_notificacoes/{id} {
      allow read: if isAuth() && (
        resource.data.destinatario_uid == request.auth.uid ||
        (isEP() && resource.data.destinatario_uid == 'ep_escalada')
      );
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.destinatario_uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida']);
    }

    // Fila de e-mails de workflow (envio diferido): a Cloud Function enfileira;
    // o EP lê a fila e marca como enviado pelo navegador (EmailJS é client-side).
    match /wf_emails_pendentes/{id} {
      allow read: if isAuth() && isEP();
      allow create: if isAuth() && isEP();
      allow update: if isAuth() && isEP()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enviado', 'tentativas', 'enviado_em', 'erro', '_atualizado_em']);
      allow delete: if isAuth() && isEP();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
