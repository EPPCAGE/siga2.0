rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // isEP() usa Custom Claim {perfil} definido pela Cloud Function setUserClaims.
    // REQUISITO: as Cloud Functions devem estar deployadas E os Secrets
    // CHECK_EMAIL_URL / SET_CLAIMS_URL devem estar configurados no GitHub
    // antes de reativar as restrições isEP() nas escritas abaixo.
    // Enquanto as Claims não estiverem ativas, isEP() retorna false para todos
    // e as escritas restritas a EP falham — use isAuth() como fallback seguro.
    function isEP() {
      return isAuth() && request.auth.token.get('perfil', '') == 'ep';
    }

    // ---------------------------------------------------------------------------
    // config/ — leitura exige autenticação (leitura pública removida).
    // A verificação de e-mail antes do login usa a Cloud Function checkEmail.
    // ---------------------------------------------------------------------------
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
      // TODO: restringir escrita a isEP() após deploy das Cloud Functions e
      //       configuração dos Secrets CHECK_EMAIL_URL e SET_CLAIMS_URL.
    }

    match /processos/{procId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /publicacoes/{pubId} {
      allow read: if isAuth();
      allow write: if isAuth();
      // TODO: allow write: if isEP(); — após Custom Claims ativas
    }

    match /kpis/{id}         { allow read: if isAuth(); allow write: if isAuth(); }
    match /plano/{id}        { allow read: if isAuth(); allow write: if isAuth(); }
    match /trilhas/{id}      { allow read: if isAuth(); allow write: if isAuth(); }
    match /avisos/{id}       { allow read: if isAuth(); allow write: if isAuth(); }
    match /solicitacoes/{id} { allow read: if isAuth(); allow write: if isAuth(); }
    match /notifs/{id}       { allow read: if isAuth(); allow write: if isAuth(); }
    match /arquitetura/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /plano_metas/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /relatorios_ind/{id}{ allow read: if isAuth(); allow write: if isAuth(); }

    match /sessions/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /projPROJETOS/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /projPROGRAMAS/{id} { allow read: if isAuth(); allow write: if isAuth(); }
    // TODO: allow write: if isEP(); para projPROGRAMAS — após Custom Claims ativas

    // Cada usuário só pode escrever no próprio documento.
    match /usuarios/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
