rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Perfil do usuário via Custom Claim (definido pela Cloud Function setUserClaims).
    // O claim é atribuído automaticamente no primeiro login e renovado a cada login.
    function perfil() {
      return request.auth.token.get('perfil', 'dono');
    }

    function isEP() {
      return isAuth() && perfil() == 'ep';
    }

    // ---------------------------------------------------------------------------
    // config/ — autenticação exigida (leitura pública removida).
    // A verificação de e-mail antes do login agora usa a Cloud Function checkEmail,
    // que não expõe o documento completo e não requer autenticação Firestore.
    // ---------------------------------------------------------------------------
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isEP();
    }

    // Processos: leitura por qualquer usuário autenticado; escrita restrita a EP.
    // Donos editam seus processos via Cloud Function (roadmap) ou via regra
    // mais granular quando Custom Claims incluírem o ID do processo.
    match /processos/{procId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /publicacoes/{pubId} {
      allow read: if isAuth();
      allow write: if isEP();
    }

    match /kpis/{id}         { allow read: if isAuth(); allow write: if isAuth(); }
    match /plano/{id}        { allow read: if isAuth(); allow write: if isEP(); }
    match /trilhas/{id}      { allow read: if isAuth(); allow write: if isEP(); }
    match /avisos/{id}       { allow read: if isAuth(); allow write: if isEP(); }
    match /solicitacoes/{id} { allow read: if isAuth(); allow write: if isAuth(); }
    match /notifs/{id}       { allow read: if isAuth(); allow write: if isAuth(); }
    match /arquitetura/{id}  { allow read: if isAuth(); allow write: if isEP(); }
    match /plano_metas/{id}  { allow read: if isAuth(); allow write: if isEP(); }
    match /relatorios_ind/{id}{ allow read: if isAuth(); allow write: if isAuth(); }

    match /sessions/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /projPROJETOS/{id}  { allow read: if isAuth(); allow write: if isAuth(); }
    match /projPROGRAMAS/{id} { allow read: if isAuth(); allow write: if isEP(); }

    // Cada usuário só pode escrever no próprio documento.
    // Gestão centralizada de usuários ocorre via config/usuarios (escrita restrita a EP).
    match /usuarios/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
