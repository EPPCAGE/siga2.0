rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    function isEP() {
      return request.auth != null && request.auth.token.get('perfil', '') == 'ep';
    }

    function withinSizeLimit() {
      return request.resource.size < 20 * 1024 * 1024; // 20 MB
    }

    match /projetos/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && withinSizeLimit();
    }

    // Publicações institucionais: upload restrito ao EP (espelhando regra Firestore).
    match /publicacoes/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isEP() && withinSizeLimit();
    }

    // Auditoria: qualquer usuário autenticado pode fazer upload de evidências.
    match /auditoria/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && withinSizeLimit();
    }

    // Workflow: qualquer autenticado faz upload de anexos nas tarefas.
    match /workflow/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && withinSizeLimit();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
